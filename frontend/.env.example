# Prefer no `VITE_*` on Vercel: frontend/vercel.json proxies `/api/*` → Render (same-origin, no CORS).
# Only set this when you intentionally call Render from the browser (then configure backend CORS):
# VITE_API_BASE_URL=https://hook-mining-engine.onrender.com

# Local dev: omit — Vite proxies /api → http://localhost:8000
